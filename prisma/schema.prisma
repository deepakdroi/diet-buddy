// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                  @id @default(cuid())
  name               String
  email              String                  @unique
  password           String?
  image              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  sessions           Session[]
  accounts           Account[]
  metrics            UserMetrics?
  activityLevel      UserActivityLevel?
  goals              UserGoals?
  dietaryPreferences UserDietaryPreferences?
  dietPlans          DietPlan[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              String
  providerAccountId     String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Baseline Body Metrics
model UserMetrics {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age               Int
  gender            Gender
  height            Float // in cm
  weight            Float // in kg
  bodyFatPercentage Float? // optional
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("user_metrics")
}

// Activity Level
model UserActivityLevel {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyActivityLevel     DailyActivityLevel
  exerciseFrequency      ExerciseFrequency
  exerciseTypes          String[] // JSON array of exercise types
  averageWorkoutDuration WorkoutDuration
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("user_activity_levels")
}

// Goal Definition
model UserGoals {
  id                String            @id @default(cuid())
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryGoal       PrimaryGoal
  targetWeight      Float? // optional
  timeline          Timeline
  timelineDays      Int? // for custom timeline
  urgencyPreference UrgencyPreference
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("user_goals")
}

// Dietary Preferences
model UserDietaryPreferences {
  id                    String                @id @default(cuid())
  userId                String                @unique
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietType              DietType
  mealsPerDay           MealsPerDay
  cookingTimePreference CookingTimePreference
  budgetPreference      BudgetPreference
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@map("user_dietary_preferences")
}

// Diet Plan
model DietPlan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Calculations flattened from the JSON
  bmr                Float
  tdee               Float
  dailyCalorieTarget Float
  proteinG           Float
  carbsG             Float
  fatsG              Float

  // Relations
  meals      Meal[]
  guidelines Guideline[]
  isActive   Boolean     @default(true) // Helpful if they generate multiple plans over time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("diet_plans")
}

model Meal {
  id         String   @id @default(cuid())
  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  mealType      MealType
  mealName      String
  timeSlot      String
  totalCalories Float

  foods Food[]

  @@map("meals")
}

model Food {
  id     String @id @default(cuid())
  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  name     String
  quantity Float
  unit     String
  proteinG Float
  calories Float

  @@map("foods")
}

model Guideline {
  id         String   @id @default(cuid())
  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  category String
  note     String @db.Text // Use Text since guidelines can be long

  @@map("guidelines")
}

// Added extra standard meal types just in case future generations use them
enum MealType {
  BREAKFAST
  MID_MORNING_SNACK
  LUNCH
  EVENING_SNACK
  DINNER
  PRE_WORKOUT_SNACK
  POST_WORKOUT_SNACK
}

// Enums
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DailyActivityLevel {
  SEDENTARY // desk job, little movement
  LIGHTLY_ACTIVE // light walking 5–7k steps/day
  MODERATELY_ACTIVE // 8–12k steps/day
  VERY_ACTIVE // physical job or 12k+ steps/day
  ATHLETE // 2+ hrs intense training daily
}

enum ExerciseFrequency {
  NO_EXERCISE // No exercise
  ONE_TWO_DAYS // 1–2 days/week
  THREE_FOUR_DAYS // 3–4 days/week
  FIVE_SIX_DAYS // 5–6 days/week
  DAILY // Daily
}

enum WorkoutDuration {
  TWENTY_THIRTY // 20–30 min
  THIRTY_FORTY_FIVE // 30–45 min
  FORTY_FIVE_SIXTY // 45–60 min
  SIXTY_NINETY // 60–90 min
  NINETY_PLUS // 90+ min
}

enum PrimaryGoal {
  LOSE_FAT // Lose fat
  GAIN_MUSCLE // Gain muscle
  RECOMPOSITION // lose fat + gain muscle
  MAINTAIN_WEIGHT // Maintain weight
  IMPROVE_ENDURANCE // Improve endurance
  GENERAL_HEALTH // General health
}

enum Timeline {
  FOUR_WEEKS // 4 weeks
  EIGHT_WEEKS // 8 weeks
  TWELVE_WEEKS // 12 weeks
  SIXTEEN_PLUS // 16+ weeks
  CUSTOM // Custom (enter days)
}

enum UrgencyPreference {
  AGGRESSIVE // faster results, harder to maintain
  MODERATE // recommended
  SUSTAINABLE // slow but long-term
}

enum DietType {
  VEGETARIAN
  VEGAN
  EGGETARIAN
  NON_VEGETARIAN
  KETO
  LOW_CARB
  NO_PREFERENCE
}

enum MealsPerDay {
  TWO_MEALS // 2 meals
  THREE_MEALS // 3 meals
  FOUR_MEALS // 4 meals
  FIVE_PLUS_MEALS // 5+ meals
}

enum CookingTimePreference {
  UNDER_15_MINUTES // Under 15 minutes
  THIRTY_MINUTES // 30 minutes
  ONE_HOUR // 1 hour
  DONT_MIND // Don't mind cooking
}

enum BudgetPreference {
  BUDGET_FRIENDLY // Budget-friendly
  MODERATE // Moderate
  PREMIUM // Premium ingredients
}
